# Copy this file to android/keystore.properties and fill in your real values.
# Use forward slashes in Windows paths, for example:
# storeFile=F:/night_project/confession-app/keystore/confessly-upload-key.jks

storeFile=C:/path/to/confessly-upload-key.jks
storePassword=replace-with-store-password
keyAlias=replace-with-key-alias
keyPassword=replace-with-key-password
